generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("CUSTOMER")
  phone     String?
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings VanListing[] @relation("carrier")
  bookings Booking[]    @relation("shipper")
  reviewsGiven    Review[] @relation("reviewsGiven")
  reviewsReceived Review[] @relation("reviewsReceived")

  @@index([email])
}

model VanListing {
  id        String @id @default(cuid())
  carrierId String
  carrier   User   @relation("carrier", fields: [carrierId], references: [id], onDelete: Cascade)

  vehicleType        String
  licensePlate       String?
  originAddress      String
  destinationAddress String
  departureDate      DateTime
  arrivalDate        DateTime?

  totalWeight     Float
  totalVolume     Float
  availableWeight Float
  availableVolume Float

  pricePerKg         Float?
  pricePerCubicMeter Float?
  fixedPrice         Float?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@index([carrierId])
  @@index([departureDate])
  @@index([isActive])
}

model Booking {
  id        String     @id @default(cuid())
  listingId String
  listing   VanListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  shipperId String
  shipper   User       @relation("shipper", fields: [shipperId], references: [id], onDelete: Cascade)

  weightBooked    Float
  volumeBooked    Float
  itemDescription String
  pickupAddress   String?
  deliveryAddress String?

  totalPrice      Float
  stripePaymentId String?
  paymentStatus   String @default("pending")
  status          String @default("PENDING")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  review Review?

  @@index([listingId])
  @@index([shipperId])
  @@index([status])
}

model Review {
  id         String @id @default(cuid())
  bookingId  String @unique
  booking    Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User   @relation("reviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  targetId   String
  target     User   @relation("reviewsReceived", fields: [targetId], references: [id], onDelete: Cascade)

  rating  Int
  comment String?

  createdAt DateTime @default(now())

  @@index([targetId])
  @@index([reviewerId])
}
