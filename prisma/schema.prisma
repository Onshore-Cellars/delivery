generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum UserRole {
  CARRIER
  SUPPLIER
  YACHT_OWNER
  CREW
  ADMIN
}

enum ListingStatus {
  DRAFT
  ACTIVE
  FULL
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  QUOTE_REQUESTED
  QUOTED
  PENDING
  CONFIRMED
  PICKED_UP
  IN_TRANSIT
  CUSTOMS_HOLD
  DELIVERED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  REFUNDED
  FAILED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}

enum NotificationType {
  BOOKING_CREATED
  BOOKING_CONFIRMED
  BOOKING_STATUS_UPDATE
  BOOKING_CANCELLED
  BID_RECEIVED
  BID_ACCEPTED
  BID_REJECTED
  QUOTE_REQUESTED
  QUOTE_RECEIVED
  MESSAGE_RECEIVED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  REVIEW_RECEIVED
  LISTING_EXPIRING
  DOCUMENT_VERIFIED
  DOCUMENT_REJECTED
  SYSTEM
}

enum MessageType {
  TEXT
  SYSTEM
  QUOTE
  FILE
  LOCATION
}

enum DocumentType {
  DRIVERS_LICENSE
  PASSPORT
  NATIONAL_ID
  VEHICLE_REGISTRATION
  VEHICLE_INSURANCE
  GOODS_IN_TRANSIT_INSURANCE
  PORT_ACCESS_PERMIT
  DANGEROUS_GOODS_CERT
  OTHER
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

// ─── MODELS ───────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  password        String?
  googleId        String?   @unique
  role            UserRole
  phone           String?
  company         String?
  bio             String?
  avatarUrl       String?
  website         String?
  address         String?
  city            String?
  country         String?

  // Dual-role: users can both ship AND carry
  canCarry        Boolean   @default(false)
  canShip         Boolean   @default(true)

  // Yacht / vessel details (for YACHT_OWNER / CREW)
  yachtName       String?
  yachtMMSI       String?           // Maritime Mobile Service Identity
  yachtIMO        String?           // IMO number
  yachtFlag       String?           // Flag state
  yachtLength     Float?            // LOA in metres
  yachtType       String?           // Motor yacht, Sailing yacht, etc.
  homePort        String?
  homePortId      String?

  // Stripe
  stripeCustomerId  String?
  stripeAccountId   String?

  // Settings
  emailNotifications  Boolean  @default(true)
  smsNotifications    Boolean  @default(false)

  verified        Boolean   @default(false)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  listings         Listing[]       @relation("carrierListings")
  bookings         Booking[]       @relation("shipperBookings")
  bids             Bid[]           @relation("bidder")
  reviews          Review[]        @relation("reviewAuthor")
  receivedReviews  Review[]        @relation("reviewTarget")
  notifications    Notification[]
  sentMessages     Message[]       @relation("messageSender")
  conversations1   Conversation[]  @relation("conversationUser1")
  conversations2   Conversation[]  @relation("conversationUser2")
  quotes           Quote[]         @relation("quoteRequester")
  quotesReceived   Quote[]         @relation("quoteProvider")
  documents        Document[]
  vehicles         Vehicle[]
  savedAddresses   SavedAddress[]
  pushSubscriptions PushSubscription[]

  @@index([email])
  @@index([role])
  @@index([yachtMMSI])
}

model Listing {
  id                 String        @id @default(cuid())
  carrierId          String
  carrier            User          @relation("carrierListings", fields: [carrierId], references: [id], onDelete: Cascade)

  title              String
  description        String?

  // Vehicle
  vehicleId          String?
  vehicle            Vehicle?      @relation(fields: [vehicleId], references: [id])
  vehicleType        String
  vehicleName        String?
  vehicleReg         String?       // Number plate
  hasRefrigeration   Boolean       @default(false)
  hasTailLift        Boolean       @default(false)
  hasGPS             Boolean       @default(true)
  insuranceValue     Float?

  // Route
  originPort         String
  originRegion       String?
  originCountry      String?
  originLat          Float?
  originLng          Float?
  destinationPort    String
  destinationRegion  String?
  destinationCountry String?
  destinationLat     Float?
  destinationLng     Float?
  stops              String?       // JSON array of intermediate stops
  estimatedDistance   Float?        // km

  // Schedule
  departureDate      DateTime
  estimatedArrival   DateTime?
  isRecurring        Boolean       @default(false)
  recurringSchedule  String?       // e.g. "weekly", "biweekly"

  // Capacity
  totalCapacityKg    Float
  totalCapacityM3    Float
  availableKg        Float
  availableM3        Float
  maxItemLength      Float?        // cm — for oversized items
  maxItemWidth       Float?
  maxItemHeight      Float?

  // Pricing
  pricePerKg         Float?
  pricePerM3         Float?
  flatRate           Float?
  currency           String        @default("EUR")
  minimumCharge      Float?

  // Bidding
  biddingEnabled     Boolean       @default(false)
  minBidPrice        Float?

  // Accepted cargo types (JSON array)
  acceptedCargo      String?       // e.g. ["Provisions","Equipment","Wine"]
  restrictedItems    String?       // Items NOT allowed

  // Status & meta
  status             ListingStatus @default(ACTIVE)
  featured           Boolean       @default(false)
  viewCount          Int           @default(0)

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  bookings           Booking[]
  bids               Bid[]
  quotes             Quote[]

  @@index([carrierId])
  @@index([vehicleId])
  @@index([status])
  @@index([departureDate])
  @@index([originPort])
  @@index([destinationPort])
  @@index([featured])
  @@index([status, departureDate])
  @@index([originPort, destinationPort])
}

model Booking {
  id                String        @id @default(cuid())
  listingId         String
  listing           Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  shipperId         String
  shipper           User          @relation("shipperBookings", fields: [shipperId], references: [id], onDelete: Cascade)

  // Cargo
  cargoDescription  String
  cargoType         String?
  weightKg          Float
  volumeM3          Float
  itemCount         Int           @default(1)
  specialHandling   String?
  temperatureReq    String?       // e.g. "2-8°C"
  isFragile         Boolean       @default(false)
  isDangerous       Boolean       @default(false)
  customsRequired   Boolean       @default(false)
  declaredValue     Float?

  // Pickup
  pickupAddress     String?
  pickupCity        String?
  pickupCountry     String?
  pickupContact     String?
  pickupPhone       String?
  pickupEmail       String?
  pickupDate        DateTime?
  pickupNotes       String?

  // Delivery
  deliveryAddress   String?
  deliveryCity      String?
  deliveryCountry   String?
  deliveryContact   String?
  deliveryPhone     String?
  deliveryEmail     String?
  deliveryNotes     String?
  yachtName         String?
  berthNumber       String?
  marinaName        String?

  // Pricing
  totalPrice        Float
  platformFee       Float         @default(0)
  carrierPayout     Float         @default(0)
  currency          String        @default("EUR")

  // Payment
  stripePaymentId       String?
  stripePaymentIntentId String?
  paymentStatus         PaymentStatus @default(PENDING)
  paidAt                DateTime?

  // Status & Tracking
  status            BookingStatus @default(PENDING)
  trackingCode      String?       @unique
  estimatedDelivery DateTime?
  actualDelivery    DateTime?

  // Delivery time window
  deliveryTimeWindow String?      // "morning" (8-12), "afternoon" (12-17), "evening" (17-21), "any"

  // Proof of delivery
  podSignature      String?
  podPhotoUrl       String?
  podNotes          String?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  review            Review?
  trackingEvents    TrackingEvent[]
  liveTracking      LiveTracking[]
  documents         BookingDocument[]

  @@index([listingId])
  @@index([shipperId])
  @@index([status])
  @@index([trackingCode])
  @@index([paymentStatus])
  @@index([listingId, status])
  @@index([shipperId, status])
}

model Bid {
  id          String    @id @default(cuid())
  listingId   String
  listing     Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bidderId    String
  bidder      User      @relation("bidder", fields: [bidderId], references: [id], onDelete: Cascade)

  amount      Float
  currency    String    @default("EUR")
  weightKg    Float
  volumeM3    Float
  message     String?
  cargoType   String?
  status      BidStatus @default(PENDING)
  expiresAt   DateTime?

  counterOffer  Float?
  counterMessage String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([listingId])
  @@index([bidderId])
  @@index([status])
}

model Quote {
  id            String   @id @default(cuid())
  listingId     String?
  listing       Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  requesterId   String
  requester     User     @relation("quoteRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  providerId    String?
  provider      User?    @relation("quoteProvider", fields: [providerId], references: [id], onDelete: SetNull)

  // Request details
  originPort      String
  destinationPort String
  cargoDescription String
  cargoType       String?
  weightKg        Float
  volumeM3        Float
  preferredDate   DateTime?
  specialRequirements String?

  // Quote response
  quotedPrice     Float?
  quotedCurrency  String    @default("EUR")
  validUntil      DateTime?
  responseMessage String?

  status          String    @default("PENDING") // PENDING, QUOTED, ACCEPTED, EXPIRED, CANCELLED

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([requesterId])
  @@index([providerId])
  @@index([status])
}

model TrackingEvent {
  id          String   @id @default(cuid())
  bookingId   String
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  status      String
  location    String?
  lat         Float?
  lng         Float?
  description String
  photoUrl    String?
  timestamp   DateTime @default(now())

  @@index([bookingId])
  @@index([timestamp])
}

model Review {
  id          String   @id @default(cuid())
  bookingId   String   @unique
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation("reviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  targetId    String
  target      User     @relation("reviewTarget", fields: [targetId], references: [id], onDelete: Cascade)

  rating          Int       // 1-5
  comment         String?
  communicationRating Int?  // 1-5
  timelinessRating    Int?  // 1-5
  conditionRating     Int?  // 1-5

  response        String?   // Carrier can respond to review
  responseAt      DateTime?

  createdAt   DateTime @default(now())

  @@index([targetId])
  @@index([authorId])
  @@index([rating])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        NotificationType
  title       String
  message     String
  linkUrl     String?
  metadata    String?          // JSON

  read        Boolean          @default(false)
  readAt      DateTime?
  emailSent   Boolean          @default(false)

  createdAt   DateTime         @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read, createdAt])
}

model Conversation {
  id        String   @id @default(cuid())
  user1Id   String
  user1     User     @relation("conversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id   String
  user2     User     @relation("conversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)

  subject   String?
  bookingRef String?  // Optional link to a booking

  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())

  messages  Message[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
  @@index([lastMessageAt])
}

model Message {
  id              String       @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User         @relation("messageSender", fields: [senderId], references: [id], onDelete: Cascade)

  content         String
  type            MessageType  @default(TEXT)
  attachmentUrl   String?

  read            Boolean      @default(false)
  readAt          DateTime?

  createdAt       DateTime     @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
}

// ─── VEHICLE REGISTRY ────────────────────────────────────────────────────────

model Vehicle {
  id              String   @id @default(cuid())
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Registration
  registrationPlate String?
  registrationCountry String?
  vinNumber       String?

  // Vehicle specs
  make            String          // e.g. Ford
  model           String          // e.g. Transit Custom
  year            Int?
  vehicleType     String          // Van, Truck, Refrigerated Van, etc.
  colour          String?

  // Capacity (verified from vehicle lookup or manual)
  maxPayloadKg    Float?
  cargoVolumeM3   Float?
  cargoLengthCm   Float?
  cargoWidthCm    Float?
  cargoHeightCm   Float?

  // Features
  hasRefrigeration Boolean  @default(false)
  hasTailLift      Boolean  @default(false)
  hasGPS           Boolean  @default(true)
  hasRacking       Boolean  @default(false)

  // Insurance
  insuranceProvider String?
  insuranceExpiry   DateTime?
  goodsInTransitInsurance Boolean @default(false)
  goodsInTransitMax Float?       // Max cover amount

  // MOT / roadworthiness
  motExpiry       DateTime?
  roadTaxExpiry   DateTime?

  verified        Boolean  @default(false)
  active          Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  listings        Listing[]

  @@index([ownerId])
  @@index([registrationPlate])
}

// ─── DOCUMENTS (Driver ID, Permits, Insurance) ──────────────────────────────

model Document {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  type            DocumentType
  name            String         // Display name, e.g. "UK Driving License"
  fileUrl         String?        // URL to uploaded file
  fileKey         String?        // Storage key for deletion
  documentNumber  String?        // License number, passport number, etc.
  issuingCountry  String?
  issueDate       DateTime?
  expiryDate      DateTime?

  status          DocumentStatus @default(PENDING)
  reviewNotes     String?        // Admin notes on rejection etc.
  reviewedAt      DateTime?
  reviewedBy      String?        // Admin user ID

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([userId, type])
}

// ─── PORTS DATABASE ─────────────────────────────────────────────────────────

model Port {
  id              String   @id @default(cuid())
  name            String
  code            String?  @unique    // UN/LOCODE or custom code
  type            String              // marina, commercial_port, shipyard, anchorage
  country         String
  countryCode     String?             // ISO 3166-1 alpha-2
  region          String?
  city            String?
  lat             Float
  lng             Float

  // Facilities
  maxDraft        Float?              // Max draft in metres
  maxLOA          Float?              // Max vessel length
  hasCustoms      Boolean  @default(false)
  hasFuel         Boolean  @default(false)
  hasProvisions   Boolean  @default(false)
  hasCrane        Boolean  @default(false)
  hasStorage      Boolean  @default(false)
  vhfChannel      String?

  // Access requirements
  requiresPortPass Boolean @default(false)
  requiresDriverID Boolean @default(false)
  accessNotes     String?

  // Meta
  website         String?
  phone           String?
  timezone        String?
  popular         Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([country])
  @@index([type])
  @@index([popular])
  @@index([lat, lng])
  @@index([name])
}

// ─── LIVE DRIVER TRACKING ───────────────────────────────────────────────────

model LiveTracking {
  id              String   @id @default(cuid())
  bookingId       String
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  // Driver shares a tracking session
  shareToken      String   @unique @default(cuid())  // Public token for tracking URL
  isActive        Boolean  @default(true)
  startedAt       DateTime @default(now())
  endedAt         DateTime?

  // Latest position
  lat             Float?
  lng             Float?
  heading         Float?           // Degrees
  speed           Float?           // km/h
  lastUpdated     DateTime?

  // Route info
  stopsTotal      Int      @default(0)
  stopsCompleted  Int      @default(0)
  etaMinutes      Int?             // Estimated minutes to delivery
  routePolyline   String?          // Encoded polyline for route display

  @@index([bookingId])
  @@index([shareToken])
  @@index([isActive])
}

// ─── BOOKING DOCUMENTS (invoices, customs, delivery notes) ──────────────────

model BookingDocument {
  id              String   @id @default(cuid())
  bookingId       String
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  uploadedById    String   // User who uploaded

  name            String              // Display name
  type            String              // invoice, customs_declaration, packing_list, delivery_note, photo, certificate, other
  fileUrl         String?             // URL to uploaded file
  fileKey         String?             // Storage key
  fileSize        Int?                // Bytes
  mimeType        String?             // e.g. application/pdf

  notes           String?             // Additional context
  visibleToDriver Boolean @default(true)  // Can the carrier/driver see this?
  visibleToShipper Boolean @default(true) // Can the shipper see this?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([bookingId])
  @@index([type])
}

// ─── COMMUNITY BOARD ────────────────────────────────────────────────────────

model CommunityPost {
  id              String   @id @default(cuid())
  authorId        String
  title           String
  content         String
  category        String   @default("general")  // general, routes, tips, wanted, services, news
  tags            String?  // JSON array of tags

  likes           Int      @default(0)
  views           Int      @default(0)
  pinned          Boolean  @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  replies         CommunityReply[]

  @@index([category])
  @@index([authorId])
  @@index([pinned])
  @@index([createdAt])
}

model CommunityReply {
  id              String        @id @default(cuid())
  postId          String
  post            CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId        String
  content         String
  likes           Int           @default(0)

  createdAt       DateTime      @default(now())

  @@index([postId])
  @@index([authorId])
}

// ─── SAVED ADDRESSES ────────────────────────────────────────────────────────

model SavedAddress {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  label           String              // e.g. "Home", "Office", "Port Antibes"
  type            String   @default("other") // pickup, delivery, other
  address         String
  city            String?
  region          String?
  country         String?
  postcode        String?
  lat             Float?
  lng             Float?

  contactName     String?
  contactPhone    String?
  contactEmail    String?
  notes           String?             // e.g. "Gate code: 1234"

  // Marina/port specifics
  marinaName      String?
  berthNumber     String?
  yachtName       String?
  portAccessNotes String?

  isDefault       Boolean  @default(false)
  usageCount      Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([userId, type])
}

// ─── PUSH SUBSCRIPTIONS ─────────────────────────────────────────────────────

model PushSubscription {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint        String
  p256dh          String              // Public key
  auth            String              // Auth secret
  userAgent       String?

  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, endpoint])
  @@index([userId])
  @@index([active])
}
