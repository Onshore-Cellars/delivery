# ─── DATABASE ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/onshore_deliver"
DIRECT_URL="postgresql://user:password@localhost:5432/onshore_deliver"

# ─── AUTH ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── STRIPE ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── GOOGLE ───────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY="AIza..."
# GOOGLE_CLIENT_ID="..."       # Optional: Google OAuth
# GOOGLE_CLIENT_SECRET="..."   # Optional: Google OAuth

# ─── EMAIL (choose one) ──────────────────────────────────────────
# Option 1: SMTP
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your@email.com"
# SMTP_PASS="your-app-password"

# Option 2: Resend
# RESEND_API_KEY="re_..."

# From address for all emails
# EMAIL_FROM="info@onshoredelivery.com"

# ─── AI (Claude) ─────────────────────────────────────────────────
# ANTHROPIC_API_KEY="sk-ant-..."  # Required for AI features

# ─── ADMIN ────────────────────────────────────────────────────────
# Comma-separated emails that auto-get ADMIN role on login
ADMIN_EMAILS="admin@onshoredelivery.com"

# ─── FILE STORAGE (S3-compatible) ─────────────────────────────────
# STORAGE_BUCKET="onshore-deliver"
# STORAGE_REGION="eu-west-1"
# STORAGE_ACCESS_KEY="..."
# STORAGE_SECRET_KEY="..."
# STORAGE_ENDPOINT=""           # For R2/MinIO
# STORAGE_PUBLIC_URL=""         # CDN URL

# ─── AIS VESSEL TRACKING ────────────────────────────────────────
# AISSTREAM_API_KEY="..."       # Free API key from https://aisstream.io

# ─── CRON / AUTOMATION ───────────────────────────────────────────
# CRON_SECRET="..."             # Shared secret for cron endpoints

# ─── PUSH NOTIFICATIONS ──────────────────────────────────────────
# VAPID_PUBLIC_KEY="..."
# VAPID_PRIVATE_KEY="..."
# VAPID_EMAIL="mailto:admin@onshoredelivery.com"
