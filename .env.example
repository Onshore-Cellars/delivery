# Database - PostgreSQL
# EASIEST: Add "Neon Postgres" from Vercel Dashboard > Storage tab
# Vercel auto-sets these env vars when you connect a Neon database
POSTGRES_PRISMA_URL="postgresql://user:password@host/database?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host/database?sslmode=require"

# Auth Secret (change this in production)
NEXTAUTH_SECRET="your-secret-key-here"
